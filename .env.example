# Server-only MiniMax credentials for the optional AI Set Coach.
# Never expose this value with a NEXT_PUBLIC_ prefix.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2

# WHOOP integration (register a free app at https://developer.whoop.com).
# The redirect URI must exactly match the one configured on the WHOOP app.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# Fitbit integration via the Google Health API (developers.google.com/health —
# the legacy Fitbit Web API shuts down Sept 2026). Create an OAuth client in
# the Google Cloud Console, enable the Health API, and add yourself as a test
# user (googlehealth.* scopes are Restricted; Testing mode avoids the review,
# but Google then expires refresh tokens after ~7 days — reconnect when the
# card shows the reauth banner). The redirect URI must match exactly.
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=http://localhost:3000/api/fitbit/callback

# Encrypts stored WHOOP/Google access and refresh tokens (AES-256-GCM).
# Generate with: openssl rand -base64 32. Keep stable across deployments.
OAUTH_TOKEN_ENCRYPTION_KEY=

# Better Auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum
BETTER_AUTH_URL=http://localhost:3000

# Private directory for progress-photo files (served only via /api/photos/[id]).
# Dev default is ./var/photos when unset. In production set an absolute path on
# a persistent volume, e.g. /data/photos.
PHOTOS_DIR=

# APNs push notifications (iOS app, lib/push/apns.ts). Dormant scaffold:
# leave these unset and sendPushToUser() is a guaranteed no-op. Create a .p8
# APNs auth key in App Store Connect (Certificates, Identifiers & Profiles >
# Keys), note its Key ID and your Team ID, and paste the key's PEM contents
# (literal "\n" line breaks are fine — they're normalized at read time).
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.majidtahir.tracker
APNS_AUTH_KEY=
# Sandbox (development builds / Xcode debug): https://api.sandbox.push.apple.com
# Production (App Store / TestFlight builds): https://api.push.apple.com
APNS_HOST=https://api.sandbox.push.apple.com

# Shared secret for the scheduled-push cron route (/api/cron/notify).
# Generate with `openssl rand -hex 32`, then add crontab entries like:
#   0 7 * * *   curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://<host>/api/cron/notify
#   0 16 * * 0  curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://<host>/api/cron/notify
CRON_SECRET=
