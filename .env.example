# Server-only MiniMax credentials for the optional AI Set Coach.
# Never expose this value with a NEXT_PUBLIC_ prefix.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2

# WHOOP integration (register a free app at https://developer.whoop.com).
# The redirect URI must exactly match the one configured on the WHOOP app.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# Better Auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum
BETTER_AUTH_URL=http://localhost:3000

# Private directory for progress-photo files (served only via /api/photos/[id]).
# Dev default is ./var/photos when unset. In production set an absolute path on
# a persistent volume, e.g. /data/photos.
PHOTOS_DIR=
