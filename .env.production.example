# Copy to .env.production and fill in. Loaded by docker-compose (env_file).
# NEVER commit the filled-in .env.production (it's gitignored).

# ---- Canonical public origin (your domain behind the reverse proxy) ----
# Must be the HTTPS URL users hit. Better Auth uses this for cookie domain,
# secure-cookie flag, and CSRF origin checks. Must match trustedOrigins below.
BETTER_AUTH_URL=https://tracker.yourdomain.com

# 32+ char random secret. Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Comma-separated origins allowed to call auth (the iOS Capacitor webview loads
# your prod domain as its origin, so this is just the prod URL). See the code
# note in lib/auth.ts — replace the hardcoded LAN IP with this domain.
BETTER_AUTH_TRUSTED_ORIGINS=https://tracker.yourdomain.com,capacitor://localhost

# ---- Database (overridden by compose to file:/data/tracker.db) ----
# DATABASE_URL is set in docker-compose.yml; leave unset here.

# Private progress-photo storage on the persistent data volume.
PHOTOS_DIR=/data/photos

# ---- WHOOP integration (optional) ----
# Register the redirect URI EXACTLY in the WHOOP developer console.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://tracker.yourdomain.com/api/whoop/callback

# ---- Fitbit integration via the Google Health API (optional) ----
# Google Cloud Console OAuth client; register the redirect URI EXACTLY.
# googlehealth.* scopes are Restricted — keep the consent screen in Testing
# mode for personal use (refresh tokens then expire ~7 days; reconnect from
# the recovery page) or pass Google's review to publish.
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=https://tracker.yourdomain.com/api/fitbit/callback

# 32 random bytes, base64 encoded (openssl rand -base64 32). Back this up:
# losing or changing it requires users to reconnect their wearable accounts.
OAUTH_TOKEN_ENCRYPTION_KEY=

# ---- Scheduled push notifications (optional) ----
# Bearer secret for /api/cron/notify (openssl rand -hex 32). Crontab:
#   0 7 * * *   curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://tracker.yourdomain.com/api/cron/notify
#   0 16 * * 0  curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://tracker.yourdomain.com/api/cron/notify
CRON_SECRET=

# Apple Push Notification service token credentials. The .p8 key may be stored
# with literal \n escapes. Production builds use the production APNs host.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=fit.progression.app
APNS_AUTH_KEY=
APNS_HOST=https://api.push.apple.com

# ---- MiniMax AI (optional — Set Coach / program builder / dashboard coach) ----
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2
